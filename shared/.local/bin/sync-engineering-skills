#!/bin/bash
# =============================================================================
# sync-engineering-skills — Sync mattpocock/skills from submodule
#
# Uses external/mattpocock-skills/ submodule as source.
# Categories: engineering, productivity, misc
#
# Usage:
#   sync-engineering-skills          # show diff
#   sync-engineering-skills --pr     # apply + create PR
# =============================================================================

set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
SUBMODULE="$DOTFILES_DIR/external/mattpocock-skills"
SKILLS_DIR="$DOTFILES_DIR/shared/opencode-skills"

# Categories: <upstream subpath> -> <local subdir>
declare -A CATEGORIES=(
  ["skills/engineering"]="engineering"
  ["skills/productivity"]="productivity"
  ["skills/misc"]="misc"
)

# Skills to skip from upstream
SKIP="ask-matt README.md"

echo "=== Sync Engineering Skills ==="
echo "  Dotfiles:  $DOTFILES_DIR"
echo "  Submodule: $SUBMODULE"

# --- Update submodule ---
echo ""
echo "Updating submodule..."
git -C "$DOTFILES_DIR" submodule update --remote external/mattpocock-skills 2>&1 | tail -1

UPSTREAM_HASH=$(git -C "$SUBMODULE" rev-parse HEAD)
echo "  Upstream commit: $UPSTREAM_HASH"

# --- Diff all categories ---
echo ""
echo "=== Diff ==="
HAS_CHANGES=false

for upstream_path in "${!CATEGORIES[@]}"; do
  local_subdir="${CATEGORIES[$upstream_path]}"
  src="$SUBMODULE/$upstream_path"
  dst="$SKILLS_DIR/$local_subdir"

  [ -d "$src" ] || { echo "  [$local_subdir] upstream dir not found, skipping"; continue; }
  mkdir -p "$dst"

  changes=$(diff -rq "$dst" "$src" 2>/dev/null | grep -v "__pycache__" || true)
  if [ -n "$changes" ]; then
    echo ""
    echo "[$local_subdir]"
    echo "$changes"
    HAS_CHANGES=true

    # Detail diff for changed files
    while IFS= read -r line; do
      file=$(echo "$line" | grep "differ" | awk '{print $2}')
      [ -z "$file" ] && continue
      rel="${file#$dst/}"
      [ -f "$src/$rel" ] && echo "" && echo ">> $rel" && diff -u "$dst/$rel" "$src/$rel" || true
    done <<< "$changes"
  fi
done

if ! $HAS_CHANGES; then
  echo "Already up to date."
fi

# --- Apply + PR if --pr flag ---
if [ "${1:-}" = "--pr" ]; then
  echo ""
  echo "=== Creating PR ==="
  cd "$DOTFILES_DIR"

  BRANCH="sync-engineering-skills-$(date +%Y%m%d)"
  git rev-parse --verify "$BRANCH" 2>/dev/null && git branch -D "$BRANCH"
  git checkout -b "$BRANCH"

  for upstream_path in "${!CATEGORIES[@]}"; do
    local_subdir="${CATEGORIES[$upstream_path]}"
    src="$SUBMODULE/$upstream_path"
    dst="$SKILLS_DIR/$local_subdir"

    [ -d "$src" ] || continue
    mkdir -p "$dst"

    for skill_dir in "$src"/*/; do
      skill=$(basename "$skill_dir")
      skip=false
      for s in $SKIP; do [ "$skill" = "$s" ] && skip=true && break; done
      $skip && continue
      rm -rf "$dst/$skill"
      cp -r "$skill_dir" "$dst/$skill"
    done
  done

  git add external/mattpocock-skills "$SKILLS_DIR"
  if git diff --cached --quiet; then
    echo "No changes to commit."
    git checkout main
    git branch -D "$BRANCH"
  else
    git commit -m "chore: sync skills from mattpocock ($UPSTREAM_HASH)"
    git push -u origin "$BRANCH"
    gh pr create \
      --repo AlexONEX/dotfiles \
      --base main \
      --head "$BRANCH" \
      --title "chore: sync skills from mattpocock" \
      --body "Sync from [mattpocock/skills](https://github.com/mattpocock/skills/commit/$UPSTREAM_HASH)"
    echo "PR created!"
  fi
else
  echo ""
  echo "Run with --pr to apply and create a PR."
fi

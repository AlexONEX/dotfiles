{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/meta/schema/3rd/luv/schema.json",
  "runtime": {
    "version": "LuaJIT",
    "path": [
      "lua/?.lua",
      "lua/?/init.lua"
    ]
  },
  "workspace": {
    "library": [
      "$VIMRUNTIME/lua",
      "$VIMRUNTIME/lua/vim/lsp",
      "${3rd}/luv/library"
    ],
    "checkThirdParty": false
  },
  "diagnostics": {
    "globals": ["vim"]
  },
  "telemetry": {
    "enable": false
  }
}
